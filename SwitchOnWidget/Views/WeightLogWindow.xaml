<Window x:Class="SwitchOnWidget.Views.WeightLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="체중 기록" Width="960" Height="720" MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="230" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="체중 기록과 예상선" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="실제 체중 셀을 수정한 뒤 저장하세요. 체중은 30~200kg만 허용됩니다."
                           Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="닫기" Width="74" Click="CloseButton_Click" />
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
            <Border Style="{StaticResource SectionCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="시작 대비 변화" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="ChangeText" FontSize="22" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SectionCard}" Margin="3,0">
                <StackPanel>
                    <TextBlock Text="최근 7개 기록 평균" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="AverageText" FontSize="22" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SectionCard}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="입력한 날짜" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="RecordedDaysText" FontSize="22" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource SectionCard}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="● 보수" Foreground="#7AA8E8" Margin="0,0,15,0" />
                    <TextBlock Text="● 표준" Foreground="#62D6A7" Margin="0,0,15,0" />
                    <TextBlock Text="● 도전" Foreground="#E9B75A" Margin="0,0,15,0" />
                    <TextBlock Text="● 실제" Foreground="#F07C91" />
                </StackPanel>
                <Canvas x:Name="WeightCanvas" Grid.Row="1" Background="#10151C"
                        SizeChanged="WeightCanvas_SizeChanged" />
            </Grid>
        </Border>

        <DataGrid x:Name="WeightDataGrid" Grid.Row="3" ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  Background="#171D27" Foreground="{StaticResource TextBrush}"
                  BorderBrush="#354052" RowBackground="#171D27" AlternatingRowBackground="#1D2531"
                  HorizontalGridLinesBrush="#303A49" VerticalGridLinesBrush="#303A49"
                  Margin="0,0,0,12">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#242D3A" />
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                    <Setter Property="Padding" Value="8" />
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="6,4" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="날짜" Binding="{Binding DateLabel}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Day" Binding="{Binding Day}" IsReadOnly="True" Width="60" />
                <DataGridTextColumn Header="보수" Binding="{Binding Conservative, StringFormat={}{0:0.0}}" IsReadOnly="True" Width="75" />
                <DataGridTextColumn Header="표준" Binding="{Binding Standard, StringFormat={}{0:0.0}}" IsReadOnly="True" Width="75" />
                <DataGridTextColumn Header="도전" Binding="{Binding Challenge, StringFormat={}{0:0.0}}" IsReadOnly="True" Width="75" />
                <DataGridTextColumn Header="실제 체중" Binding="{Binding ActualWeight, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" Width="100" />
                <DataGridTextColumn Header="메모" Binding="{Binding Memo, UpdateSourceTrigger=LostFocus}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="4">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{StaticResource MutedTextBrush}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="CSV 내보내기" Click="ExportButton_Click" />
                <Button Content="체중 기록 저장" Background="{StaticResource AccentDarkBrush}"
                        Foreground="{StaticResource AccentBrush}" Click="SaveButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
